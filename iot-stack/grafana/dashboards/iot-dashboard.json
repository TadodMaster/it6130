      "title": "Temperature",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb_iot" },
          "query": "from(bucket: \"iot_data\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"sensor_data\")\n  |> filter(fn: (r) => r._field == \"temperature\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> keep(columns: [\"_time\", \"_value\", \"device_id\"])",
          "refId": "A"
        }
